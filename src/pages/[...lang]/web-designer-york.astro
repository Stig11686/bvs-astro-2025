---
import LocationPageLayout from "@/layouts/components/LocationPageLayout.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";

export function getStaticPaths() {
  return generatePaths();
}

// Page configuration
const pageConfig = {
  // Meta
  title:
    "Web Design in York | WordPress Websites for York Businesses | BVS Web Design",
  metaDescription:
    "WordPress web design for York businesses. Websites built to get enquiries, rank on Google, and work while you're busy. Strategy, design, build and ongoing care.",

  // Hero
  location: "York",
  region: "North Yorkshire",
  heroHeadline:
    'Websites that get York businesses more <em class="text-accent italic">enquiries</em>, more <em class="text-accent italic">bookings</em> and found on Google.',
  heroExcerpt:
    "I'm Steve — I design and build WordPress websites for service businesses in York and across North Yorkshire. Not templated, not outsourced. Strategy, design, build, launch, and ongoing care. All from one person who actually picks up the phone.",
  heroImage: "/images/steve-1.jpg",
  heroImageAlt: "Steve Marks - Web designer serving York businesses",

  // Results section
  resultsHeadline: "A website that works while you're busy serving customers.",
  resultsText:
    "The best websites do their job while you're doing yours. They answer questions before anyone picks up the phone, build trust before the first meeting, and turn strangers into enquiries without you lifting a finger. That's what I build for York businesses.",
  testimonialQuote:
    "My contact form works really well for me, it's helped me book out my boutique for months in advance. Steve understood exactly what I wanted — something different, something that felt like my brand. The website captures everything Maidens & Ravens is about, and brides find us every week because of it.",
  testimonialAuthor: "Elizabeth Matfin",
  testimonialBusiness: "Maidens and Ravens",
  testimonialLocation: "Micklegate, York",
  testimonialAvatar: "/images/testimonial/elizabeth.jpg",

  // Why work with me
  whyWorkHeadline: "Why York businesses work with me",
  features: [
    {
      title: "Strategy-first approach",
      text: "Every site starts with your business goals, not a template. We work out what you need before touching any code.",
    },
    {
      title: "Built to convert",
      text: "Designed around getting enquiries, not just looking good. Every page has a job to do.",
    },
    {
      title: "WordPress, no lock-in",
      text: "You own everything — domain, hosting, files. Move it whenever you want. No hostage situations.",
    },
    {
      title: "Local understanding",
      text: "I work with businesses across York and North Yorkshire. I know the area and the customers you serve.",
    },
    {
      title: "One point of contact",
      text: "No account managers, no ticket queues. Just me. When you call, I answer.",
    },
    {
      title: "Ongoing support",
      text: "I don't disappear at launch. Website care plans keep your site secure, backed up, and looked after.",
    },
  ],

  // Portfolio section - use slugs to pull from portfolio collection
  portfolioEyebrow: "Who I work with in York",
  portfolioText:
    "From dental practices to bridal boutiques, beauty clinics to hospitality — these are some of the businesses I've helped get found and get enquiries.",
  portfolioSlugs: ["maidens-and-ravens"],

  // Success story
  successStoryEyebrow: "York Success Story",
  successStoryBusiness: "Maidens & Ravens",
  successStoryLocation: "York",
  successStoryText:
    "A bridal boutique as distinctive as the dresses they sell. Elizabeth needed a website that matched her vision — gothic, sustainable, one-of-a-kind. We built it, and now she's booked out every Saturday for six months.",
  successStoryMetrics: [
    { value: "6", label: "Months booked out" },
    { value: "1k+", label: "Monthly visitors" },
    { value: "5★", label: "Google review rating" },
  ],

  // Location testimonial
  locationTestimonialQuote:
    "Steve understood exactly what I wanted — something different, something that felt like my brand. The website captures everything Maidens & Ravens is about, and brides find us every week because of it.",
  locationTestimonialAuthor: "Elizabeth",
  locationTestimonialBusiness: "Maidens & Ravens, York",
  locationTestimonialAvatar:
    "/images/testimonial/elizabeth-maidens-ravens.webp",

  // Process steps
  processSteps: [
    {
      num: "01",
      title: "Free call",
      description:
        "A proper conversation about your business, not your colour scheme.",
    },
    {
      num: "02",
      title: "Discovery",
      description:
        "Your customers, what they need to see, and what's getting in the way.",
    },
    {
      num: "03",
      title: "Design",
      description: "Drafts you can revise, built around the path to enquiry.",
    },
    {
      num: "04",
      title: "Build",
      description: "Hand-built WordPress. Fast, secure, yours to keep.",
    },
    {
      num: "05",
