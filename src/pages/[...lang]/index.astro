---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import BannerEditorial from "@/components/sections/BannerEditorial.astro";
import ProofStrip from "@/components/sections/ProofStrip.astro";
import HelpCards from "@/components/sections/HelpCards.astro";
import ServicesSection from "@/components/sections/ServicesSection.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";
import AboutOne from "@/components/sections/AboutOne.astro";
import PortfolioSection from "@/components/sections/PortfolioSection.astro";
import TestimonialCreative from "@/components/sections/TestimonialCreative.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import ContactSection from "@/components/sections/ContactSection.astro";

export function getStaticPaths() {
  return generatePaths();
}

const page = await getEntryCTM("homepage", "-index", Astro.currentLocale);
---

<Base {...page?.data} footerLayout="footer-1">
  <BannerEditorial />
  <ProofStrip />
  <HelpCards />
  <AboutOne />
  <PortfolioSection />
  <TestimonialCreative />
  <BlogSection />
  <ContactSection />
  <CallToAction content={page?.data.ctaSection} sectionSpaceTop={false} />
</Base>
