---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";
import CustomButton from "@/components/CustomButton.astro";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getLocaleUrlCTM } from "@/lib/utils/languageParser.ts";
import extractSlug from "@/lib/utils/extractSlug";
import ContactSection from "@/layouts/components/sections/ContactSection.astro";
import TestimonialArticle from "@/layouts/components/sections/TestimonialArticle.astro";

export function getStaticPaths() {
  return generatePaths();
}

// Fetch blog posts for related reading section - in specific order
const allPosts = await getCollectionCTM("blog", Astro.currentLocale);
const relatedSlugs = [
  "why-your-business-website-needs-a-care-plan-and-what-happens-without-one",
  "wordpress-isnt-slow-bad-builds-are",
  "who-owns-my-website",
];

// Get unique posts in the order specified
const relatedPosts = relatedSlugs
  .map((slug) => allPosts?.find((post) => post.data.customSlug === slug))
  .filter((post) => post !== undefined);

const pageData = {
  title: "Website Maintenance Packages & Care Plans | BVS Web Design",
  metaDescription:
    "Website maintenance packages for growing businesses — hosting, updates, backups and security, all handled by a real person based in Skipton, North Yorkshire, not a ticket queue. From £35/mo.",
};

const FAQ_ITEMS = [
  {
    question: "How much does website maintenance cost?",
    answer:
      "Plans start at £35/month for hosting, backups, updates and monitoring, rising to £99 and £249 for monthly edit time, security scans and ongoing improvements. The right plan depends on how much you lean on your site — a brochure site needs less than one that drives daily enquiries.",
  },
  {
    question: "What's included in a website care plan?",
    answer:
      "At minimum: managed hosting, regular WordPress updates, off-site backups, uptime monitoring and email support. Higher tiers add same-day fixes, monthly edits, malware scanning, SEO actions and a regular strategy call.",
  },
  {
    question: "Do I need a maintenance plan for a WordPress site?",
    answer:
      "Realistically, yes. WordPress and its plugins release updates constantly — security patches, fixes, new features. A site left un-updated for months is the single most common way small business sites get hacked or break. A plan keeps on top of it so you don't have to.",
  },
  {
    question:
      "I find updating my own site a hassle — can you just do it for me?",
    answer:
      "That's exactly what the monthly edit time on Active and Growth is for. No wrestling with image sizes or odd file formats, no fighting the page builder — just send me the photos and words, and I'll put them on the site for you, looking right. Most small changes are done the same day.",
  },
  {
    question: "Do you only work with Yorkshire businesses?",
    answer:
      "I'm based in Skipton and work with businesses right across Yorkshire — but maintenance is handled remotely, so location isn't a barrier. Plenty of clients I've never met in person; the site's looked after just the same.",
  },
  {
    question: "Can I cancel?",
    answer:
      "Yes — every plan is month-to-month with no lock-in. No setup fee either, for sites I've built.",
  },
];

const SUPPORT_PLANS = [
  {
    name: "Essentials",
    price: "£35",
    cadence: "/ month",
    blurb:
      "The basics, properly handled — so nothing breaks while you get on with running the business.",
    features: [
      "Managed WordPress hosting",
      "Weekly off-site backups",
      "1 hour of edits each month",
      "Core, theme & plugin updates",
      "Uptime monitoring",
      "Email support",
    ],
    featured: false,
  },
  {
    name: "Active",
    price: "£99",
    cadence: "/ month",
    blurb:
      "Everything in Essentials, plus a real person making small improvements every month.",
    features: [
      "Everything in Essentials",
      "Same-day priority fixes",
      "Security hardening & malware scans",
      "Quarterly performance check",
      "2 hours of edits each month",
    ],
    featured: true,
  },
  {
    name: "Growth",
    price: "£249",
    cadence: "/ month",
    blurb:
      "For businesses treating the website as a channel that should keep getting better.",
    features: [
      "Everything in Active",
      "3 hours of edits each month",
      "Monthly SEO actions",
      "Conversion improvements",
      "Quarterly strategy call",
    ],
    featured: false,
  },
];
---

<Base {...pageData} footerLayout="footer-1">
  <!-- Hero -->
  <section class="py-16 lg:py-20">
    <div class="container">
      <div class="label text-accent mb-4">
        — Website Maintenance & Care Plans
      </div>
      <h1
        class="font-primary max-w-[20ch] text-4xl leading-[0.98] font-normal tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
        Website maintenance plans that keep your site <em
          class="text-accent italic">
          earning
        </em>.
      </h1>
      <p
        class="font-primary text-ink-2 mt-6 max-w-[58ch] text-lg leading-relaxed md:text-xl">
        Security, updates, backups and hosting — all handled, so your site keeps
        working while you focus on running the business. Built for growing
        businesses that need their website looked after by a real person, not a
        ticket queue. Based in Skipton, I work with businesses throughout North
        Yorkshire, West Yorkshire and the wider Yorkshire region.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <CustomButton
          label="Book a Quick Call →"
          url="https://tidycal.com/bvswebdesign/30-minute-intro-call"
          hoverEffect="creative-fill"
          class="effect-color-accent"
        />
        <span class="text-ink-2 text-sm">
          <a
            href="/services/website-support/#contact"
            class="hover:text-accent underline transition-colors">
            Send a Message →
          </a>
        </span>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="border-border-light border-t py-10">
    <div class="container">
      <h2
        class="font-primary mb-4 text-3xl font-normal tracking-tight sm:text-5xl">
        Simple website maintenance packages
      </h2>
      <p
        class="font-primary text-ink-2 mb-10 max-w-[65ch] text-lg leading-relaxed">
        Every plan covers the essentials — hosting, backups, updates and
        security — handled quietly in the background. Step up a tier when you
        want real decision making, strategy and improvements every month.
      </p>
      <div class="border-border-light grid grid-cols-1 border md:grid-cols-3">
        {
          SUPPORT_PLANS.map((plan, i) => (
            <div
              class:list={[
                "relative p-8",
                i < SUPPORT_PLANS.length - 1 &&
                  "border-border-light border-b md:border-r md:border-b-0",
                plan.featured && "bg-stone-2",
              ]}>
              {plan.featured && (
                <div class="font-secondary bg-accent absolute top-0 right-0 px-3 py-1 text-[10px] tracking-wider text-white uppercase">
                  Most popular
                </div>
              )}
              <h3 class="font-primary text-2xl font-normal tracking-tight">
                {plan.name}
              </h3>
              <div class="mt-3 mb-4 flex items-baseline gap-2">
                <span class="font-primary text-accent text-5xl leading-none italic">
                  {plan.price}
                </span>
                <span class="label">{plan.cadence}</span>
              </div>
              <p class="text-ink-2 mb-5 min-h-[4rem] text-sm leading-relaxed">
                {plan.blurb}
              </p>
              <div class="border-border-light/50 border-t">
                {plan.features.map((feature) => (
                  <div class="text-ink-2 border-border-light/50 flex gap-3 border-b py-2 text-sm">
                    <span class="text-accent">✓</span>
                    <span>{feature}</span>
                  </div>
                ))}
              </div>
              <CustomButton
                label="Book a Quick Call →"
                url="https://tidycal.com/bvswebdesign/30-minute-intro-call"
                hoverEffect="creative-fill"
                class="effect-color-accent mt-6"
              />
            </div>
          ))
        }
      </div>
      <p class="label text-ink-2 mt-4">
        All plans are month-to-month · cancel any time · no setup fee for sites
        I've built
      </p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="border-border-light border-t py-16 lg:py-20">
    <div class="container">
      <h2
        class="font-primary mb-4 text-3xl font-normal tracking-tight sm:text-5xl">
        What a website care plan actually covers
      </h2>
      <p
        class="font-primary text-ink-2 mb-10 max-w-[65ch] text-lg leading-relaxed">
        A maintenance plan means someone is regularly checking the parts of your
        website that actually matter to your business — can customers contact
        you, are enquiries coming through, are your key pages working properly,
        and is everything still doing its job?
      </p>
      <div
        class="border-border-light grid grid-cols-1 border-t border-l md:grid-cols-2">
        <div
          class="included-card border-border-light border-r border-b p-8 md:p-9">
          <span class="font-primary text-accent text-xl italic">01</span>
          <h3
            class="font-primary mt-3 mb-3 max-w-[20ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            Hosting that's actually managed.
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[46ch] text-sm leading-relaxed md:text-[0.9rem]">
            Your site lives on fast, secure WordPress hosting I look after
            directly — no separate hosting bill to chase, no support desk in
            another time zone.
          </p>
        </div>
        <div
          class="included-card border-border-light border-r border-b p-8 md:p-9">
          <span class="font-primary text-accent text-xl italic">02</span>
          <h3
            class="font-primary mt-3 mb-3 max-w-[20ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            Updates, done carefully.
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[46ch] text-sm leading-relaxed md:text-[0.9rem]">
            WordPress core, your theme and plugins all need regular updating.
            Skip it and you get broken layouts, security holes, or a site that
            simply stops loading. I handle updates and check nothing breaks
            afterwards.
          </p>
        </div>
        <div
          class="included-card border-border-light border-r border-b p-8 md:p-9">
          <span class="font-primary text-accent text-xl italic">03</span>
          <h3
            class="font-primary mt-3 mb-3 max-w-[20ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            Backups you'll never need to think about.
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[46ch] text-sm leading-relaxed md:text-[0.9rem]">
            Weekly off-site backups, so if the worst happens, your site comes
            back — not a month of lost work.
          </p>
        </div>
        <div
          class="included-card border-border-light border-r border-b p-8 md:p-9">
          <span class="font-primary text-accent text-xl italic">04</span>
          <h3
            class="font-primary mt-3 mb-3 max-w-[20ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            Security and monitoring.
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[46ch] text-sm leading-relaxed md:text-[0.9rem]">
            Uptime monitoring on every plan, with security hardening and malware
            scans on Active and Growth. You hear from me if something's wrong,
            usually before you've noticed.
          </p>
        </div>
        <div
          class="included-card border-border-light border-r border-b p-8 md:col-span-2 md:p-9">
          <span class="font-primary text-accent text-xl italic">05</span>
          <h3
            class="font-primary mt-3 mb-3 max-w-[20ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            You send it, I post it.
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[65ch] text-sm leading-relaxed md:text-[0.9rem]">
            Ever tried adding a photo to your own site and hit a wall — wrong
            size, wrong format, won't upload, comes out stretched? On Active and
            Growth, that's my job, not yours. Send me the photos and the words;
            I'll get them live, properly sized and looking right. The "can you
            just change this..." jobs come off your to-do list for good.
          </p>
        </div>
      </div>
      <p
        class="font-primary text-ink-2 mt-10 max-w-[65ch] text-lg leading-relaxed">
        If you run a WordPress site for a growing business anywhere in
        Yorkshire, this is the website maintenance and support that keeps it off
        your plate.
      </p>
    </div>
  </section>

  <!-- Why It Matters -->
  <section class="border-border-light bg-stone-2 border-t py-16 lg:py-20">
    <div class="container">
      <!-- Header row -->
      <div class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-16">
        <div>
          <div class="label text-accent mb-4">
            — Why do I need a maintenance plan?
          </div>
          <h2
            class="font-primary text-3xl leading-tight font-normal tracking-tight sm:text-5xl lg:text-5xl">
            A website isn't "finished" the day it launches — maintenance plans
            keep the good work going.
          </h2>
        </div>
        <div class="flex items-end">
          <p class="font-primary text-ink-2 text-lg leading-relaxed">
            A care plan takes the worry out of your website. Instead of reacting
            to problems after they've cost you customers, everything's handled
            in the background — so your site keeps earning while you focus on
            running the business.
          </p>
        </div>
      </div>

      <!-- Comparison tables -->
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <!-- Left table - Left to Drift -->
        <div class="border-border-light border bg-transparent p-8 md:p-10">
          <h3
            class="font-secondary text-ink-2 mb-6 text-sm tracking-wider uppercase">
            Left to Drift
          </h3>
          <ul>
            <li
              class="text-ink-2 border-border-light/50 flex gap-3 border-t py-3">
              <span class="font-medium text-red-600">✕</span>
              <span>Plugins fall out of date</span>
            </li>
            <li
              class="text-ink-2 border-border-light/50 flex gap-3 border-t py-3">
              <span class="font-medium text-red-600">✕</span>
              <span>Security gaps open up</span>
            </li>
            <li
              class="text-ink-2 border-border-light/50 flex gap-3 border-t py-3">
              <span class="font-medium text-red-600">✕</span>
              <span>The contact form stops sending</span>
            </li>
            <li
              class="text-ink-2 border-border-light/50 flex gap-3 border-t py-3">
              <span class="font-medium text-red-600">✕</span>
              <span>You find out when a customer says the site is down</span>
            </li>
          </ul>
        </div>

        <!-- Right table - On a Care Plan -->
        <div class="bg-theme-dark p-8 md:p-10">
          <h3
            class="font-secondary mb-6 text-sm tracking-wider text-white/70 uppercase">
            On a Care Plan
          </h3>
          <ul>
            <li class="flex gap-3 border-t border-white/10 py-3">
              <span class="text-accent font-medium">✓</span>
              <span class="text-white">
                Updates applied and tested before they break
              </span>
            </li>
            <li class="flex gap-3 border-t border-white/10 py-3">
              <span class="text-accent font-medium">✓</span>
              <span class="text-white">
                Security monitored, hardened and patched
              </span>
            </li>
            <li class="flex gap-3 border-t border-white/10 py-3">
              <span class="text-accent font-medium">✓</span>
              <span class="text-white">
                Forms checked — with an alert the moment one fails
              </span>
            </li>
            <li class="flex gap-3 border-t border-white/10 py-3">
              <span class="text-accent font-medium">✓</span>
              <span class="text-white">
                You hear about it from me, usually already fixed
              </span>
            </li>
          </ul>
        </div>
      </div>

      <!-- CTA Banner -->
      <div
        class="border-border-light mt-8 flex flex-col gap-6 border p-8 md:flex-row md:items-center md:justify-between md:p-10">
        <p
          class="font-primary max-w-[55ch] text-lg leading-relaxed md:text-2xl">
          For most growing businesses, the peace of mind — and a site that stays
          fast and findable — <em class="text-accent font-medium">
            pays for itself the first time it saves you a lost weekend.
          </em>
        </p>
        <CustomButton
          label="Get Peace of Mind →"
          url="/services/website-support/#contact"
          hoverEffect="creative-fill"
          class="effect-color-accent shrink-0"
        />
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="border-border-light border-t py-16 lg:py-20">
    <div class="container">
      <div class="prose-styles">
        <TestimonialArticle
          author="Elizabeth Matfin"
          authorTitle="Owner, Maidens and Ravens Bridal Boutique, York"
          image="/images/testimonial/elizabeth.jpg"
          quote="I accidently went viral on TikTok and sent 5000 visitors to my site in one go - it crashed the site as we'd not prepared for such traffic!  Steve had it sorted within the hour. That peace of mind is worth every penny. I don't have to think about the technical stuff anymore; I just know it's handled."
        />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-border-light border-t py-16 lg:py-20">
    <div class="container">
      <h2
        class="font-primary mb-10 text-3xl font-normal tracking-tight sm:text-5xl">
        Everything you need to know about my website maintenance packages
      </h2>
      <div
        class="hs-accordion-group border-border-light mx-auto w-full max-w-4xl border-y">
        {
          FAQ_ITEMS.map((item, index) => (
            <div
              class:list={[
                "hs-accordion border-border-light border-b",
                index === 0 && "active",
              ]}
              id={`faq-accordion-${index}`}>
              <button
                class="hs-accordion-toggle font-primary text-dark hover:text-accent flex w-full items-center justify-between py-5 text-left text-lg font-medium transition-colors"
                aria-expanded={index === 0 ? "true" : "false"}
                aria-controls={`faq-content-${index}`}>
                <span>{item.question}</span>
                <svg
                  class="hs-accordion-active:rotate-180 text-accent size-5 shrink-0 transition-transform duration-300"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>
              <div
                id={`faq-content-${index}`}
                class:list={[
                  "hs-accordion-content w-full overflow-hidden transition-[height] duration-300",
                  index !== 0 && "hidden",
                ]}
                role="region"
                aria-labelledby={`faq-accordion-${index}`}>
                <p class="text-ink-2 pr-8 pb-5 leading-relaxed">
                  {item.answer}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Not Quite Right Fork -->
  <section class="border-border-light border-t py-16 lg:py-20">
    <div class="container">
      <!-- Header row -->
      <div class="mb-10 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2
            class="font-primary text-3xl font-normal tracking-tight sm:text-5xl">
            Need more than website maintenance?
          </h2>
        </div>
        <div class="flex items-end">
          <p class="font-primary text-ink-2 text-lg leading-relaxed">
            If that's not where you are right now, you probably need something
            else first — and I'd rather point you to the right thing than sell
            you the wrong one.
          </p>
        </div>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <a
          href="/services/website-rescue/"
          class="fork-card border-border-light text-dark hover:bg-stone-2 block border p-8 no-underline transition-colors md:p-9">
          <div class="flex items-baseline justify-between">
            <span class="label text-accent">Website Rescue</span>
            <span class="font-primary text-accent text-base italic">
              &rarr;
            </span>
          </div>
          <h3
            class="font-primary mt-3 mb-3 max-w-[24ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            Your site's already broken, inherited or your developer has vanished
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[46ch] text-sm leading-relaxed md:text-[0.9rem]">
            That's a rescue job. I take it over, get you back in control of your
            own site, and sort out what's wrong.
          </p>
        </a>
        <a
          href="/services/website-design/"
          class="fork-card border-border-light text-dark hover:bg-stone-2 block border p-8 no-underline transition-colors md:p-9">
          <div class="flex items-baseline justify-between">
            <span class="label text-accent">Website Design</span>
            <span class="font-primary text-accent text-base italic">
              &rarr;
            </span>
          </div>
          <h3
            class="font-primary mt-3 mb-3 max-w-[24ch] text-2xl leading-tight font-normal tracking-tight md:text-[1.7rem]">
            No site yet, or yours is well overdue a redesign?
          </h3>
          <p
            class="text-ink-2 m-0 max-w-[46ch] text-sm leading-relaxed md:text-[0.9rem]">
            Start from the ground up with a new WordPress site built around
            getting enquiries, then keep it on a care plan afterwards.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Related Reading -->
  <section class="border-border-light border-t py-16 lg:py-20">
    <div class="container">
      <h2
        class="font-primary mb-10 text-3xl font-normal tracking-tight sm:text-5xl">
        Important things to know about website maintenance
      </h2>
      <div class="grid gap-x-6 gap-y-10 md:grid-cols-2 xl:grid-cols-3">
        {
          relatedPosts.map((post) => {
            const postUrl = getLocaleUrlCTM(
              extractSlug(post),
              Astro.currentLocale,
              "blog",
            );
            return (
              <article class="group">
                <a href={postUrl} class="relative block overflow-hidden">
                  {post.data.image && (
                    <OptimizedImage
                      src={post.data.image}
                      alt={post.data.title}
                      class="h-87.5! min-w-full object-cover transition duration-500 group-hover:scale-105"
                      width={600}
                      height={600}
                    />
                  )}
                </a>
                <div class="mt-6">
                  <h3 class="text-h4-sm md:text-h5 mb-6 font-medium">
                    <a
                      href={postUrl}
                      class="hover:text-accent inline-block transition-colors">
                      {post.data.title}
                    </a>
                  </h3>
                  <a
                    href={postUrl}
                    class="font-secondary border-dark hover:border-accent hover:text-accent border-b pb-1 text-sm tracking-wider uppercase transition-colors">
                    Read More →
                  </a>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <div id="contact">
    <ContactSection noPaddingBottom={false} />
  </div>
</Base>

<style>
  .label {
    font-family: var(--font-secondary);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .text-ink-2 {
    color: var(--color-ink-2, #44403c);
  }
  .bg-stone-2 {
    background-color: var(--color-stone-2, #e7e5e3);
  }

  /* Contact form privacy policy link */
  #contact :global(a) {
    color: white;
  }
  #contact :global(a:hover) {
    color: var(--color-accent);
  }
</style>
