---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import CustomButton from "@/components/CustomButton.astro";
import parseTomlToJson from "@/lib/utils/parseTomlToJson";

export function getStaticPaths() {
  return generatePaths();
}

const config = parseTomlToJson("./src/config/config.toml");

const pageData = {
  title: "Portfolio | Web Design Case Studies",
  metaDescription: "A small portfolio, written up honestly. Service businesses across Yorkshire and the UK — bridal, hospitality, dental, beauty and community organisations.",
};

// Get all portfolio items
let projects = await getCollectionCTM(
  config.settings.portfolioFolder as "portfolio",
  Astro.currentLocale,
);

// Sort by date
projects = sortByDate(projects);

// Helper to get project URL
const getProjectUrl = (project: any) => {
  const slug = project.data.customSlug || project.id.replace(/^english\//, '').replace(/\.mdx?$/, '');
  return `/portfolio/${slug}/`;
};

// Get first category as sector
const getSector = (project: any) => {
  return project.data.categories?.[0] || 'Project';
};

// Get main stat from information
const getStat = (project: any) => {
  const resultInfo = project.data.information?.find((i: any) => i.label?.toLowerCase().includes('result'));
  return resultInfo?.value || '';
};
---

<Base {...pageData} footerLayout="footer-1">
  <!-- Hero -->
  <section class="py-16 lg:py-20">
    <div class="container">
      <div class="label text-accent mb-4">— Recent work</div>
      <h1 class="font-primary font-normal text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[0.98] tracking-tight max-w-[18ch]">
        A small portfolio, written up <em class="italic text-accent">honestly</em>.
      </h1>
      <p class="font-primary text-lg md:text-xl leading-relaxed text-ink-2 mt-6 max-w-[56ch]">
        Service businesses across Yorkshire and the UK — bridal, hospitality, dental, beauty and community organisations. A few of the more recent ones.
      </p>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="border-t border-border-light">
    <div class="container px-0 md:px-[var(--container-padding)]">
      <div class="grid grid-cols-1 md:grid-cols-2">
        {projects.map((project, i) => (
          <a
            href={getProjectUrl(project)}
            class:list={[
              "group block p-6 md:p-8 transition-colors hover:bg-stone-2",
              i % 2 === 0 && "md:border-r border-border-light",
              "border-b border-border-light"
            ]}
          >
            <!-- Image Placeholder -->
            <div class="relative overflow-hidden bg-stone-2 mb-5">
              {project.data.image ? (
                <img
                  src={project.data.image}
                  alt={project.data.title}
                  class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full aspect-[4/3] flex items-center justify-center bg-stone-2 text-dark/60 font-primary text-lg italic px-6 text-center">
                  {project.data.title}
                </div>
              )}
              {project.data.coming_soon && (
                <div class="absolute top-4 left-4 label bg-dark text-white px-3 py-1">
                  Coming soon
                </div>
              )}
            </div>

            <!-- Meta -->
            <div class="flex justify-between items-baseline mb-2">
              <span class="label text-ink-2">{getSector(project)}</span>
              {getStat(project) && (
                <span class="label text-accent">{getStat(project)}</span>
              )}
            </div>

            <!-- Title -->
            <h2 class="font-primary text-2xl md:text-3xl font-normal tracking-tight leading-snug">
              {project.data.title}
              <span class="inline-block ml-2 text-accent italic text-lg group-hover:translate-x-1 transition-transform">→</span>
            </h2>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-14 bg-stone-2">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 items-start">
        <h2 class="font-primary text-3xl md:text-4xl font-normal tracking-tight leading-tight">
          Want results like <em class="italic text-accent">these</em>?
        </h2>
        <div>
          <p class="font-primary text-lg leading-relaxed text-ink-2 mb-8 max-w-2xl">
            Every project here started with a conversation. If your website isn't generating the enquiries it should, let's talk about what's possible.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <CustomButton
              label="Start a Project →"
              url="https://tidycal.com/bvswebdesign/start-a-project"
              hoverEffect="creative-fill"
              class="effect-color-accent"
            />
            <CustomButton
              label="Book a Free Audit"
              url="https://tidycal.com/bvswebdesign/30-minute-meeting"
              variant="outline"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .label {
    font-family: var(--font-secondary);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .text-ink-2 {
    color: var(--color-ink-2, #44403c);
  }
  .bg-stone-2 {
    background-color: var(--color-stone-2, #e7e5e3);
  }
</style>
