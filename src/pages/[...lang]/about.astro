---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";
import CustomButton from "@/components/CustomButton.astro";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";

export function getStaticPaths() {
  return generatePaths();
}

const pageData = {
  title: "About Steve Marks | Web Designer, Skipton",
  metaDescription: "I'm Steve Marks, a freelance web designer based in Skipton, North Yorkshire. I build WordPress websites that generate enquiries for local service businesses.",
};

const HOW_IT_WORKS = [
  {
    num: '01',
    title: 'I talk about your business, not just your website.',
    body: 'Before I touch any design, I want to understand who your customers are, what they need to see before they trust you, and what\'s currently getting in the way of them getting in touch.',
  },
  {
    num: '02',
    title: 'I build around conversion, not just aesthetics.',
    body: 'Every decision — layout, copy, calls to action, page structure — is made with one question in mind: will this help a visitor take the next step?',
  },
  {
    num: '03',
    title: 'You get a website you\'re proud of and a business that benefits.',
    body: 'Most of my clients tell me they didn\'t realise how much their old website was costing them until they saw what a new one could do.',
  },
];

const STATS = [
  { value: '20+', label: 'Yorkshire businesses helped', body: 'Local service businesses getting real results from their websites.' },
  { value: '90%+', label: 'Report increased enquiries', body: 'Clients who see more leads after their website rebuild.' },
  { value: 'Direct', label: 'Communication always', body: 'You work with me directly — no account managers or handoffs.' },
];
---

<Base {...pageData} footerLayout="footer-1">
  <!-- Hero Section -->
  <section class="py-16 lg:py-20">
    <div class="container">
      <div class="label text-accent mb-4">— About</div>
      <h1 class="font-primary font-normal text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[0.98] tracking-tight max-w-[20ch]">
        Hi, I'm Steve. I build websites that actually <em class="italic text-accent">earn</em>.
      </h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mt-8 max-w-5xl">
        <p class="font-primary text-lg leading-relaxed text-ink-2">
          I'm a freelance web designer based in Skipton, North Yorkshire. I work with local service businesses whose websites look fine on the surface — but aren't generating the enquiries their owners deserve.
        </p>
        <p class="font-primary text-lg leading-relaxed text-ink-2">
          Most web designers build websites. I build lead generators. That means starting with the outcome (more enquiries) and working backwards to the design.
        </p>
      </div>
      <div class="mt-8">
        <CustomButton
          label="Book a Free Website Review →"
          url="https://tidycal.com/bvswebdesign/30-minute-meeting"
          hoverEffect="creative-fill"
          class="effect-color-accent"
        />
      </div>
    </div>
  </section>

  <!-- Why Section -->
  <section class="py-12 border-t border-border-light">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 items-start">
        <h2 class="font-primary text-3xl md:text-4xl font-normal tracking-tight leading-tight">
          Results, not just <em class="italic text-accent">redesigns</em>
        </h2>
        <div class="space-y-5">
          <p class="font-primary text-lg leading-relaxed text-ink-2">
            There's no shortage of web designers in Yorkshire. Most of them will build you something that looks good, hand you the login details, and wish you luck.
          </p>
          <p class="font-primary text-lg leading-relaxed text-dark">
            <strong>That's not how I work.</strong>
          </p>
          <p class="font-primary text-lg leading-relaxed text-ink-2">
            I got into this because I kept seeing the same problem: business owners investing in a website, then wondering why nobody was getting in touch. The design looked fine. The branding was nice. But the phone wasn't ringing.
          </p>
          <p class="font-primary text-lg leading-relaxed text-ink-2">
            The issue was almost never the design. It was the strategy behind it. Unclear calls to action. No thought given to what a visitor needs to see before they trust you. Contact forms that went nowhere.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Case Study - Dark Section -->
  <section class="py-14 bg-theme-dark text-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div>
          <div class="label text-accent mb-4">— Proof</div>
          <h2 class="font-primary text-3xl md:text-4xl font-normal tracking-tight leading-tight text-white">
            Here's what that looks like <em class="italic text-accent">in practice</em>.
          </h2>
        </div>
        <div>
          <p class="font-primary text-lg leading-relaxed text-white/80">
            <strong class="text-white">Ilkley Dental Care</strong> had a website that looked decent but was silently losing them patients. The contact form was broken. The phone number was buried. Visitors couldn't find what they needed.
          </p>
          <p class="font-primary text-lg leading-relaxed text-white/80 mt-5">
            After a rebuild focused on getting people to make contact, they went from almost no online enquiries to <span class="text-accent font-semibold">30+ per month</span> — from exactly the same traffic.
          </p>
          <a
            href="/portfolio/ilkley-dental-care/"
            class="inline-block mt-6 font-primary italic text-white border-b border-white/50 hover:text-accent hover:border-accent transition-colors"
          >
            Read the full Ilkley Dental story →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How I Work Section -->
  <section class="py-14">
    <div class="container">
      <h2 class="font-primary text-3xl md:text-4xl font-normal tracking-tight leading-tight mb-10">
        What working with me <em class="italic text-accent">looks like</em>
      </h2>
      <div class="border-t border-border-light">
        {HOW_IT_WORKS.map((step) => (
          <div class="grid grid-cols-1 md:grid-cols-[auto_1fr_2fr] gap-4 md:gap-8 items-baseline py-6 border-b border-border-light/50">
            <div class="font-primary italic text-2xl text-accent">{step.num}</div>
            <h3 class="font-primary text-xl md:text-2xl font-normal tracking-tight leading-snug">{step.title}</h3>
            <p class="text-sm text-ink-2 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About Steve - Two Column -->
  <section class="py-14 bg-stone-2">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <OptimizedImage
            src="/images/results/headshot_10.jpg"
            alt="Steve Marks, freelance web designer based in Skipton"
            class="w-full h-auto"
          />
        </div>
        <div>
          <div class="label text-accent mb-4">— A bit about me</div>
          <h2 class="font-primary text-3xl md:text-4xl font-normal tracking-tight leading-tight mb-6">
            Steve <em class="italic">Marks</em>
          </h2>
          <div class="space-y-5 text-ink-2">
            <p class="font-primary text-lg leading-relaxed">
              I've been designing and building websites for years, and I'm based in Skipton in the Yorkshire Dales. I work with service businesses across Yorkshire — from Ilkley and Keighley to York and beyond.
            </p>
            <p class="font-primary text-lg leading-relaxed">
              I work as a freelancer, which means you deal directly with me from the first conversation to launch day and beyond. No account managers, no handoffs, no surprises.
            </p>
            <p class="font-primary text-lg leading-relaxed">
              When a project calls for specialist skills — copywriting, photography, SEO — I bring in trusted collaborators from my network. But I'm always your main point of contact and always responsible for the outcome.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-14 border-t border-border-light">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-border-light">
        {STATS.map((stat, i) => (
          <div class:list={[
            "py-8",
            i > 0 && "md:border-l border-border-light md:pl-8",
            i < STATS.length - 1 && "border-b md:border-b-0 border-border-light"
          ]}>
            <div class="font-primary italic text-5xl md:text-6xl text-accent leading-none">{stat.value}</div>
            <h3 class="font-primary text-lg md:text-xl font-normal tracking-tight mt-3 mb-2">{stat.label}</h3>
            <p class="text-sm text-ink-2 leading-relaxed">{stat.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Closing CTA Section -->
  <section class="py-14 bg-stone-2">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 items-start">
        <h2 class="font-primary text-3xl md:text-4xl font-normal tracking-tight leading-tight">
          Ready to find out what your website <em class="italic text-accent">could be doing</em>?
        </h2>
        <div>
          <p class="font-primary text-lg leading-relaxed text-ink-2 mb-8 max-w-2xl">
            Start with a free website review. I'll take a look at your current site and tell you the three most important things holding it back — whether you end up working with me or not.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <CustomButton
              label="Book a Free Website Review →"
              url="https://tidycal.com/bvswebdesign/30-minute-meeting"
              hoverEffect="creative-fill"
              class="effect-color-accent"
            />
            <CustomButton
              label="See My Work"
              url="/portfolio/"
              variant="outline"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .label {
    font-family: var(--font-secondary);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .text-ink-2 {
    color: var(--color-ink-2, #44403c);
  }
  .bg-stone-2 {
    background-color: var(--color-stone-2, #e7e5e3);
  }
</style>
