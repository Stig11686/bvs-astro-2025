---
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { supportedLanguages } from "@/lib/utils/languageParser.ts";
import { slugifyyy, titleify } from "@/lib/utils/textConverter";
import { sortByDate } from "@/lib/utils/sortFunctions";
import parseTomlToJson from "@/lib/utils/parseTomlToJson";

export async function getStaticPaths() {
  const paths = await Promise.all(
    supportedLanguages.map(async (lang) => {
      const config = parseTomlToJson("./src/config/config.toml");
      const {
        blogFolder: blogFolder,
        multilingual: { defaultLanguage, showDefaultLangInUrl },
      } = config.settings;

      const categories = await getTaxonomy(
        blogFolder as "blog",
        "categories",
        lang.languageCode,
      );

      const paths = categories.map((category) => ({
        params: {
          category: slugifyyy(category.slug),
          lang:
            lang.languageCode === defaultLanguage && !showDefaultLangInUrl
              ? undefined
              : lang.languageCode,
        },
        props: { category, blogFolder },
      }));

      return paths;
    }),
  );

  return paths.flat();
}

const { category, blogFolder } = Astro.props;
const config = parseTomlToJson("./src/config/config.toml");

// Get all blog posts
let allPosts = await getCollectionCTM(blogFolder, Astro.currentLocale);
allPosts = sortByDate(allPosts);

// Filter out draft posts in production
if (import.meta.env.PROD) {
  allPosts = allPosts?.filter((post) => !post.data.draft);
}

// Filter posts by current category
const posts = allPosts?.filter((post) =>
  post.data.categories?.some((cat: string) => slugifyyy(cat) === slugifyyy(category.name))
) || [];

// Get unique categories from all posts for the filter tabs
const allCategories = allPosts?.flatMap((post) => post.data.categories || []) || [];
const uniqueCategories = [...new Set(allCategories)];

// Count posts
const postCount = posts?.length || 0;

const pageData = {
  title: `${titleify(category.name)} | The Journal`,
  metaDescription: `Articles about ${category.name.toLowerCase()} from BVS Web Design. Practical insights for small business owners.`,
};

// Helper to format date
const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric'
  }).format(new Date(date));
};

// Helper to get post URL
const getPostUrl = (post: any) => {
  const slug = post.data.customSlug || post.id.replace(/^english\//, '').replace(/\.mdx?$/, '');
  return `/blog/${slug}/`;
};

const currentCategorySlug = slugifyyy(category.name);
---

<Base {...pageData} footerLayout="footer-1">
  <!-- Hero -->
  <section class="py-16 lg:py-20 border-b border-border-light">
    <div class="container">
      <div class="label text-accent mb-4">— {postCount} {postCount === 1 ? 'article' : 'articles'}</div>
      <h1 class="font-primary font-normal text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[0.98] tracking-tight max-w-[16ch]">
        <em class="italic text-accent">{titleify(category.name)}</em>
      </h1>
      <p class="font-primary text-lg md:text-xl leading-relaxed text-ink-2 mt-6 max-w-[52ch]">
        Articles and insights about {category.name.toLowerCase()}.
      </p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="py-6 border-b border-border-light">
    <div class="container">
      <nav class="flex flex-wrap gap-2" aria-label="Blog categories">
        <a
          href="/blog/"
          class="filter-tab"
          data-category="all"
        >
          All
        </a>
        {uniqueCategories.map((cat) => (
          <a
            href={`/blog/category/${slugifyyy(cat)}/`}
            class:list={["filter-tab", { active: slugifyyy(cat) === currentCategorySlug }]}
            data-category={slugifyyy(cat)}
          >
            {cat}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Post Grid -->
  <section class="py-12 md:py-16">
    <div class="container">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-12">
          {posts.map((post) => (
            <article class="group">
              <!-- Image -->
              <a href={getPostUrl(post)} class="block overflow-hidden bg-stone-2 mb-5">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full aspect-[16/10] object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full aspect-[16/10] flex items-center justify-center bg-stone-2 text-dark/60 font-primary text-lg italic px-6 text-center">
                    {post.data.title}
                  </div>
                )}
              </a>

              <!-- Content -->
              <div class="flex items-center gap-3 mb-3">
                {post.data.categories?.[0] && (
                  <span class="label text-accent">{post.data.categories[0]}</span>
                )}
                <span class="text-sm text-ink-2">{formatDate(post.data.date)}</span>
              </div>
              <h3 class="font-primary text-xl md:text-2xl font-normal tracking-tight leading-snug">
                <a href={getPostUrl(post)} class="hover:text-accent transition-colors">
                  {post.data.title}
                </a>
              </h3>
              <a
                href={getPostUrl(post)}
                class="inline-block mt-3 font-primary italic text-sm text-dark border-b border-dark hover:text-accent hover:border-accent transition-colors"
              >
                Read article →
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="font-primary text-lg text-ink-2">No articles found in this category.</p>
      )}
    </div>
  </section>
</Base>

<style>
  .label {
    font-family: var(--font-secondary);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .text-ink-2 {
    color: var(--color-ink-2, #44403c);
  }
  .bg-stone-2 {
    background-color: var(--color-stone-2, #e7e5e3);
  }

  .filter-tab {
    padding: 0.5rem 1rem;
    font-family: var(--font-secondary);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--color-border-light);
    color: var(--color-ink-2, #44403c);
    transition: border-color 0.2s, color 0.2s;
  }
  .filter-tab:hover {
    border-color: var(--color-dark);
    color: var(--color-dark);
  }
  .filter-tab.active {
    background-color: var(--color-dark);
    color: white;
    border-color: var(--color-dark);
  }
</style>
