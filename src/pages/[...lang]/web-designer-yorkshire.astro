---
import LocationPageLayout from "@/layouts/components/LocationPageLayout.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";

export function getStaticPaths() {
  return generatePaths();
}

// Page configuration
const pageConfig = {
  // Meta
  title:
    "Web Design in Yorkshire | WordPress Websites for Yorkshire Businesses | BVS Web Design",
  metaDescription:
    "WordPress web design for Yorkshire businesses. Websites built to get enquiries, rank on Google, and work while you're busy. Strategy, design, build and ongoing care.",

  // Hero
  location: "Yorkshire",
  region: "North & West Yorkshire",
  heroHeadline:
    'Websites that get Yorkshire businesses more <em class="text-accent italic">enquiries</em>, more <em class="text-accent italic">bookings</em> and found on Google.',
  heroExcerpt:
    "I'm Steve — I design and build WordPress websites for service businesses across Yorkshire. Not templated, not outsourced. Strategy, design, build, launch, and ongoing care. All from one person who actually picks up the phone.",
  heroImage: "/images/steve-1.jpg",
  heroImageAlt: "Steve Marks - Web designer serving Yorkshire businesses",

  // Results section
  resultsHeadline: "A website that works while you're busy serving customers.",
  resultsText:
    "The best websites do their job while you're doing yours. They answer questions before anyone picks up the phone, build trust before the first meeting, and turn strangers into enquiries without you lifting a finger. That's what I build for Yorkshire businesses.",
  testimonialQuote:
    "Steve is fantastic! He created a beautiful website for my skin clinic. The finished result looks extremely professional, slick and stylish. He went out of his way to make sure my website was just as I wanted!",
  testimonialAuthor: "Rebecca Rennolds",
  testimonialBusiness: "Permanent Beauty & Laser",
  testimonialLocation: "York",
  testimonialAvatar: "/images/testimonial/rebecca-rennolds.webp",

  // Why work with me
  whyWorkHeadline: "Why Yorkshire businesses work with me",
  features: [
    {
      title: "Strategy-first approach",
      text: "Every site starts with your business goals, not a template. We work out what you need before touching any code.",
    },
    {
      title: "Built to convert",
      text: "Designed around getting enquiries, not just looking good. Every page has a job to do.",
    },
    {
      title: "WordPress, no lock-in",
      text: "You own everything — domain, hosting, files. Move it whenever you want. No hostage situations.",
    },
    {
      title: "Local understanding",
      text: "Based in Skipton, I work with businesses across North and West Yorkshire. I know the area and the customers you serve.",
    },
    {
      title: "One point of contact",
      text: "No account managers, no ticket queues. Just me. When you call, I answer.",
    },
    {
      title: "Ongoing support",
      text: "I don't disappear at launch. Website care plans keep your site secure, backed up, and looked after.",
    },
  ],

  // Portfolio section - use slugs to pull from portfolio collection
  portfolioEyebrow: "Who I work with across Yorkshire",
  portfolioText:
    "From dental practices to bridal boutiques, beauty clinics to hospitality — these are some of the Yorkshire businesses I've helped get found and get enquiries.",
  portfolioSlugs: [
    "ilkley-dental-care",
    "maidens-and-ravens",
    "rebecca-rennolds-permanent-beauty-and-laser",
  ],

  // Success story
  successStoryEyebrow: "Yorkshire Success Story",
  successStoryBusiness: "Ilkley Dental Care",
  successStoryLocation: "Ilkley",
  successStoryText:
    "A dental practice that went from a broken contact form and zero web enquiries to 30+ enquiries every month. Trust-critical, compliance-heavy work where every detail counts — rebuilt to actually generate business.",
  successStoryMetrics: [
    { value: "30+", label: "Enquiries per month" },
    { value: "0→1", label: "From broken to working" },
    { value: "5★", label: "Google review rating" },
  ],

  // Location testimonial
  locationTestimonialQuote:
    "I had to convince the owners to get a new website. They were so done with it and didn't see the benefit. But now we have one, we are getting more enquiries, have made it easier for patients to get in touch with us, and look more credible when people search for us.",
  locationTestimonialAuthor: "Jodie Marks",
  locationTestimonialBusiness: "Ilkley Dental Care",
  locationTestimonialAvatar: "/images/testimonial/jodie.jpg",

  // Process steps
  processSteps: [
    {
      num: "01",
      title: "Free call",
      description:
        "A proper conversation about your business, not your colour scheme.",
    },
    {
      num: "02",
      title: "Discovery",
      description:
        "Your customers, what they need to see, and what's getting in the way.",
    },
    {
      num: "03",
      title: "Design",
      description: "Drafts you can revise, built around the path to enquiry.",
    },
    {
      num: "04",
      title: "Build",
      description: "Hand-built WordPress. Fast, secure, yours to keep.",
    },
    {
      num: "05",
      title: "Launch & care",
      description: "Live, trained, and looked after long after handover.",
    },
  ],

