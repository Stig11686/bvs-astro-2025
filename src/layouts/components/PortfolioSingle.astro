---
import TOC from "./widgets/TableOfContents.astro";
import ReactIcons from "@/helpers/ReactIcons.astro";
import { markdownify } from "@/lib/utils/textConverter";
import parseTomlToJson from "@/lib/utils/parseTomlToJson";
import { useTranslations } from "@/lib/utils/languageParser";
import OptimizedImage from "./utilities/OptimizedImage.astro";
import PaginationForSingle from "./widgets/PaginationForSingle.astro";
import { render } from "astro:content";
import CustomButton from "@/components/CustomButton.astro";

let {
  collection,
  data: { title, description, images, information, categories, date },
}: {
  render: any;
  id: string;
  collection: string;
  data: {
    title: string;
    description?: string;
    images: string[];
    categories: string[];
    information: { label: string; value: string }[];
    date?: Date;
  };
} = Astro.props.content;

const config = parseTomlToJson("./src/config/config.toml");
const t = await useTranslations(Astro.currentLocale as string);
const tocHeadings = Astro.props.content.rendered?.metadata.headings;
const { Content } = await render(Astro.props.content);

const tocEnabled = !!(
  config.settings.markup.tableOfContents?.enable && tocHeadings?.length
);

// Format date for eyebrow
const year = date ? new Date(date).getFullYear() : new Date().getFullYear();
const sector = categories?.[0] || 'Project';

// Extract key stats from information
const getResultStat = () => {
  if (!information) return null;
  const result = information.find((i) => i.label?.toLowerCase().includes('result'));
  return result?.value || null;
};

if (Array.isArray(information)) {
  information = information.map((item) => {
    const newItem = { ...item };
    switch (item.value) {
      case "date":
        if (Astro.props.content.data.date) {
          newItem.value = new Date(
            Astro.props.content.data.date,
          ).toLocaleDateString(Astro.currentLocale, {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
        }
        break;
      case "categories":
        if (Astro.props.content.data.categories) {
          newItem.value = Astro.props.content.data.categories.join(", ");
        }
        break;
    }
    return newItem;
  });
}
---

<section class="pt-16 lg:pt-20">
  <div class="container">
    <!-- Hero -->
    <div class="mb-12 md:mb-16">
      <div class="label text-accent mb-4">
        — Case Study · {year} · {sector}
      </div>
      <h1 class="font-primary font-normal text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-[1.02] tracking-tight max-w-[22ch]">
        {title}
      </h1>

      {/* Stats and Description Row */}
      <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr] gap-8 mt-8 items-end">
        {description && (
          <p class="font-primary text-lg md:text-xl leading-relaxed text-ink-2 max-w-[50ch]">
            {description}
          </p>
        )}
        {getResultStat() && (
          <div class="border-l border-border-light pl-5">
            <div class="font-primary italic text-4xl text-accent leading-none">{getResultStat()}</div>
            <div class="label mt-2 text-ink-2">Key result</div>
          </div>
        )}
      </div>
    </div>

    {/* Hero Image */}
    {
      Array.isArray(images) && images.length > 0 && (
        <div class="mb-12 md:mb-16">
          {images.length > 1 ? (
            <div
              id="portfolio-slider"
              class="swiper"
              aria-label="Portfolio image slider">
              <div class="swiper-wrapper">
                {images.map((item: string, index: number) => (
                  <div class="swiper-slide h-auto!">
                    <OptimizedImage
                      src={item}
                      alt={`${title} image ${index + 1}`}
                      class="w-full aspect-video object-cover"
                    />
                  </div>
                ))}
              </div>
              {/* <!-- Left Arrow --> */}
              <button
                class="portfolio-slider-btn-prev hover:bg-accent hover:text-white absolute top-1/2 start-4 z-10 flex min-h-12 min-w-12 -translate-y-1/2 items-center justify-center bg-white border border-border-light transition duration-300"
                aria-label="Previous slide">
                <ReactIcons icon="FaArrowLeftLong" />
              </button>

              {/* <!-- Right Arrow --> */}
              <button
                class="portfolio-slider-btn-next hover:bg-accent hover:text-white absolute top-1/2 end-4 z-10 flex min-h-12 min-w-12 -translate-y-1/2 items-center justify-center bg-white border border-border-light transition duration-300"
                aria-label="Next slide">
                <ReactIcons icon="FaArrowRightLong" />
              </button>
            </div>
          ) : (
            <OptimizedImage
              src={images[0]}
              alt={title}
              class="w-full aspect-video object-cover"
            />
          )}
        </div>
      )
    }

    {/* Main Content Grid */}
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_3fr] gap-12 border-t border-border-light pt-10">
      {/* Sidebar */}
      {
        information && Array.isArray(information) && (
          <aside>
            <div class="label mb-4">Project</div>
            <div class="border-t border-border-light">
              {information.map((item) => (
                <div class="grid grid-cols-2 gap-4 py-3 border-b border-border-light/50">
                  {item.label && (
                    <span class="label text-ink-2" set:html={item.label.replace(':', '')} />
                  )}
                  <span
                    class="font-primary italic text-sm"
                    set:html={markdownify(item.value, true)}
                  />
                </div>
              ))}
            </div>
          </aside>
        )
      }

      {/* Body Content */}
      <div class="space-y-8">
        {
          tocEnabled && tocHeadings && (
            <TOC toc={tocHeadings} marker={false} />
          )
        }
        {
          Content && (
            <div class="prose-styles editorial-content has-video-modal">
              <Content />
            </div>
          )
        }
      </div>
    </div>

    {/* Next Project Navigation */}
    <div class="mt-16 pt-10 border-t border-border-light bg-stone-2 py-10">
      <div class="container">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
          <div class="label text-ink-2 mb-2">Browse more →</div>
          <h3 class="font-primary text-2xl md:text-3xl font-normal tracking-tight">
            See the rest of the <em class="italic text-accent">portfolio</em>.
          </h3>
        </div>
        <CustomButton
          label="All projects →"
          url="/portfolio/"
          hoverEffect="creative-fill"
          class="effect-color-accent"
        />
        </div>
      </div>
    </div>
  </div>

  <script>
    if (typeof window !== "undefined") {
      window.addEventListener("load", async function () {
        await import("swiper/swiper-bundle.css");
        const { Swiper } = await import("swiper");
        const { Autoplay, Pagination, Navigation } = await import(
          "swiper/modules"
        );

        // Initialize banner Swiper
        const portfolioSlider = document.querySelector(
          "#portfolio-slider",
        ) as HTMLElement;

        if (portfolioSlider) {
          // Initialize content Swiper with navigation
          new Swiper(portfolioSlider, {
            modules: [Autoplay, Pagination, Navigation],
            navigation: {
              nextEl: ".portfolio-slider-btn-next",
              prevEl: ".portfolio-slider-btn-prev",
            },
            speed: 800,
            spaceBetween: 40,
            slidesPerView: 1,
            centeredSlides: true,
            loopAdditionalSlides: 2,
            autoplay: {
              delay: 4000,
              disableOnInteraction: true,
            },
            loop: true,
          });
        }
      });
    }
  </script>
</section>

<style>
  .label {
    font-family: var(--font-secondary);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .text-ink-2 {
    color: var(--color-ink-2, #44403c);
  }
  .bg-stone-2 {
    background-color: var(--color-stone-2, #e7e5e3);
  }

  /* Editorial content styles */
  .editorial-content :global(h2) {
    font-family: var(--font-primary);
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .editorial-content :global(h3) {
    font-family: var(--font-primary);
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .editorial-content :global(h2 em),
  .editorial-content :global(h3 em) {
    color: var(--color-accent);
    font-style: normal;
  }
  .editorial-content :global(p) {
    font-family: var(--font-primary);
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-ink-2, #44403c);
    margin-bottom: 1rem;
    max-width: 60ch;
  }
  .editorial-content :global(strong) {
    color: var(--color-dark);
    font-weight: 600;
  }
</style>
