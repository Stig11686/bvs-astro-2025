---
import CustomButton from "../CustomButton.astro"
import StarIcon from "../icons/StarIcon.astro"
---

<section>
    <div class="max-w-7xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-[30px] p-8 text-dark border border-secondary">
                <div class="flex flex-col gap-6">
                    <h2 class="text-2xl font-bold">Launch Site – get online with a professional presence.</h2>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3">
                            <StarIcon color="dark" />
                            <span>Up to 5 bespoke pages tailored to your brand</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon color="dark" />
                            Mobile-responsive design
                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon color="dark" />
                            Contact form, Google Maps & on-page SEO

                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon color="dark" />
                            Basic copy written by me, based on your brief

                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon color="dark" />
                            Handover training included
                        </li>
                    </ul>
                    <div class="flex items-center gap-8">
                        <div class="p-6">
                            <p class="text-2xl font-bold"><span class="text-sm font-medium">from</span> £1,500</p>
                        </div>
                        <div class="">
                            <CustomButton
                                class="btn-accent text-white"
                                hoverEffect="creative-fill"
                                label="Get Started"
                                url="https://tidycal.com/bvswebdesign/30-minute-meeting"
                            />
                        </div>
                    </div>
                </div>

            </div>
            <div class="bg-secondary rounded-[30px] p-8 text-white border-1 border-primary">
                <div class="flex flex-col gap-6">
                    <h2 class="text-2xl font-bold">Growth Site – convert more visitors and rank in local search</h2>
                    <ul class="space-y-4">
                        <li class="flex items-center gap-3">
                            <StarIcon />
                            <span>Up to 8 designed pages</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon />
                            <span>Gallery, portfolio & testimonials</span>
                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon />
                            <span>Local SEO setup with Google Business Profile</span>

                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon />
                            Speed & Core Web Vitals optimisation

                        </li>
                        <li class="flex items-center gap-3">
                            <StarIcon />
                             3 rounds of revisions included
                        </li>
                    </ul>
                    <div class="flex items-center gap-8">
                        <div class="p-6">
                            <p class="text-2xl font-bold"><span class="text-sm font-medium">from</span> £2,500</p>
                        </div>
                        <div class="">
                            <CustomButton
                                variant="text"
                                class="!text-white"
                                label="Get Started"
                                url="https://tidycal.com/bvswebdesign/30-minute-meeting"
                            />
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>