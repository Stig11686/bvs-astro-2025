# MailerLite Configuration (for From Pretty to Profitable landing page)
# Get your API key from: https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=your_mailerlite_api_key_here

# MailerLite Group ID for the "From Pretty to Profitable" campaign
# Find this in MailerLite under Subscribers > Groups
MAILERLITE_GROUP_ID=your_group_id_here

# Calendly URL for booking calls (optional - defaults to TidyCal)
CALENDLY_URL=https://tidycal.com/bvswebdesign/30-minute-meeting

# Google API (existing)
GOOGLE_API_KEY=
GOOGLE_PLACE_ID=

# Sanity CMS (existing)
SANITY_PROJECT_ID=
SANITY_DATASET=
